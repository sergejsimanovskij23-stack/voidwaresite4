{
  "rewrites": [
    {
      "source": "/",
      "destination": "/pages/index.html"
    },
    {
      "source": "/:page",
      "destination": "/pages/:page.html"
    }
  ],
  "routes": [
    {
      "src": "/data/(.*)",
      "status": 404,
      "dest": "/404.html"
    },
    {
      "src": "/(?!txt/)(.*)\\.txt",
      "status": 404,
      "dest": "/404.html"
    }
  ]
}